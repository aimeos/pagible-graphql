{
    "name": "aimeos/pagible-graphql",
    "description": "Pagible CMS - GraphQL API",
    "keywords": ["laravel", "cms", "graphql"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "LGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-core": "~0.10",
        "nuwave/lighthouse": "^6.54",
        "mll-lab/graphql-php-scalars": "^6.4",
        "aimeos/laravel-analytics-bridge": "~1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\GraphqlServiceProvider"
            ]
        }
    }
}
